# ============================================
# 移动端 AI 自动化操作框架 - 环境变量配置示例
# 复制本文件为 .env 后按需修改
# ============================================

# ---------- LLM 配置 ----------
LLM__PROVIDER=qwen
LLM__API_KEY=sk-your-dashscope-api-key
LLM__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM__MODEL_NAME=qwen-vl-max
LLM__MAX_TOKENS=4096
LLM__TEMPERATURE=0.1
LLM__TOP_P=0.9
LLM__CONTEXT_WINDOW=32000
LLM__REQUEST_TIMEOUT=60
LLM__MAX_RETRIES=3

# ---------- 设备配置 ----------
DEVICE__SERIAL=
DEVICE__HOST=127.0.0.1
DEVICE__PORT=5555
DEVICE__ADB_PATH=adb
DEVICE__CONNECT_RETRIES=3
DEVICE__U2_INIT_ON_START=true

# ---------- 执行配置 ----------
EXECUTION__MAX_STEPS_PER_TASK=30
EXECUTION__MAX_RETRIES_PER_STEP=3
EXECUTION__MAX_TOTAL_DURATION_SECONDS=300
EXECUTION__RETRY_INTERVAL_MS=2000
EXECUTION__SCREENSHOT_MAX_SIZE=720
EXECUTION__SCREENSHOT_QUALITY=85
EXECUTION__PAGE_STABLE_WAIT_MS=5000
EXECUTION__PAGE_STABLE_POLL_MS=500

# ---------- 感知配置 ----------
PERCEPTION__SSIM_THRESHOLD_STABLE=0.98
PERCEPTION__UI_TREE_MAX_FLATTENED_NODES=150
PERCEPTION__SPATIAL_GRID_SIZE=100
PERCEPTION__PAGE_STABLE_STRUCTURAL_THRESHOLD=0.05

# ---------- 弹窗配置 ----------
POPUP__ENABLED=true
POPUP__PERMISSION_AUTO_ALLOW=true
POPUP__AD_POPUP_AUTO_CLOSE=true
POPUP__UNKNOWN_POPUP_REPORT_TO_LLM=true

# ---------- 死循环检测配置 ----------
LOOP_DETECTION__MAX_SAME_ACTIONS=3
LOOP_DETECTION__SSIM_THRESHOLD=0.95
LOOP_DETECTION__MAX_HISTORY_SIZE=50

# ---------- 坐标微调配置 ----------
COORDINATE_TUNING__ENABLE_TUNING=false
COORDINATE_TUNING__OFFSET_X=0
COORDINATE_TUNING__OFFSET_Y=0

# ---------- 日志配置 ----------
LOGGER__LOG_DIR=logs
LOGGER__LOG_LEVEL=DEBUG
LOGGER__LOG_ROTATION_MB=10
LOGGER__LOG_RETENTION_DAYS=7
LOGGER__SAVE_SCREENSHOTS=true
